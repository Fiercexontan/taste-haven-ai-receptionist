      "name": "Decide Availability",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [896, 96],
      "parameters": {
        "jsCode": "const booking = $('Code in JavaScript').first().json;\nconst existingEvents = $input.all();\n\nconst hasConflict = existingEvents.some(item => item.json && item.json.id);\n\nreturn {\n  isAvailable: !hasConflict,\n  name: booking.name,\n  phone: booking.phone,\n  whatsappPhone: booking.whatsappPhone,\n  email: booking.email,\n  emailValid: booking.emailValid,\n  emailTo: booking.emailTo,\n  party_size: booking.party_size,\n  notes: booking.notes,\n  date: booking.date,\n  time: booking.time,\n  startDateTime: booking.startDateTime,\n  endDateTime: booking.endDateTime\n};"
      }
    },
