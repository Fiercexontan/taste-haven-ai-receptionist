{
  "name": "Taste Haven - Table Cleanup",
  "nodes": [
    {
      "id": "f02bf1b5-d0c4-4d61-b302-93501a8db77e",
      "name": "Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [0, 0],
      "parameters": {
        "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] }
      }
    },
    {
      "id": "bc4dbc4f-4682-4605-bd44-d45754bcbe2f",
      "name": "Get Past Events",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [224, 0],
      "parameters": {
        "resource": "event",
        "operation": "getAll",
        "calendar": { "__rl": true, "value": "YOUR_CALENDAR@example.com", "mode": "list", "cachedResultName": "YOUR_CALENDAR@example.com" },
        "returnAll": true,
        "timeMin": "={{ $now.minus({ days: 30 }).toISO() }}",
        "timeMax": "={{ $now.toISO() }}",
        "options": {}
      },
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID", "name": "Google Calendar OAuth2 API" }
      },
      "alwaysOutputData": true
    },
    {
      "id": "64f0d1d7-7d96-47ab-a829-9ab7805982d1",
      "name": "Filter Ended Reservations",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
