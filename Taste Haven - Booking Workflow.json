    {
      "id": "83ab45fa-2997-4d40-b30c-4cd2cac9168f",
      "name": "Is Tool Call",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [224, 192],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "is-tool-call-check",
              "leftValue": "={{ $json.body.message.type }}",
              "rightValue": "tool-calls",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "0fc8fd24-ef3c-4724-808c-9ef00334c171",
      "name": "Code in JavaScript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [448, 96],
      "parameters": {
        "jsCode": "const args = $input.first().json.body.message.toolCalls[0].function.arguments;\n\nconst rawDate = (args.date || \"\").toLowerCase().trim();\nconst rawTime = (args.time || \"\").toLowerCase().trim();\n\nconst now = new Date();\nconst days = [\"sunday\",\"monday\",\"tuesday\",\"wednesday\",\"thursday\",\"friday\",\"saturday\"];\nconst months = [\"january\",\"february\",\"march\",\"april\",\"may\",\"june\",\"july\",\"august\",\"september\",\"october\",\"november\",\"december\"];\n\nfunction getNextDay(dayName) {\n  const targetDay = days.indexOf(dayName);\n  const currentDay = now.getDay();\n  let diff = targetDay - currentDay;\n  if (diff <= 0) diff += 7;\n  const result = new Date(now);\n  result.setDate(now.getDate() + diff);\n  return result;\n}\n\nlet bookingDate = null;\n\nif (rawDate.includes(\"today\")) {\n  bookingDate = new Date(now);\n} else if (rawDate.includes(\"tomorrow\")) {\n  bookingDate = new Date(now);\n  bookingDate.setDate(now.getDate() + 1);\n} else {\n  const dayMatch = days.find(d => rawDate.includes(d));\n  if (dayMatch) {\n    bookingDate = getNextDay(dayMatch);\n  }\n}\n\nif (!bookingDate) {\n  const isoMatch = rawDate.match(/(\\d{4})-(\\d{2})-(\\d{2})/);\n  if (isoMatch) {\n    bookingDate = new Date(parseInt(isoMatch[1]), parseInt(isoMatch[2]) - 1, parseInt(isoMatch[3]));\n  }\n}\n\nif (!bookingDate) {\n  const monthMatch = months.find(m => rawDate.includes(m));\n  if (monthMatch) {\n    const dayNumMatch = rawDate.match(/(\\d{1,2})/);\n    if (dayNumMatch) {\n      let year = now.getFullYear();\n      const monthIndex = months.indexOf(monthMatch);\n      const dayNum = parseInt(dayNumMatch[1]);\n      bookingDate = new Date(year, monthIndex, dayNum);\n      if (bookingDate < now) {\n        bookingDate = new Date(year + 1, monthIndex, dayNum);\n      }\n    }\n  }\n}\n\nif (!bookingDate) {\n  bookingDate = new Date(now);\n}\n\nconst yyyy = bookingDate.getFullYear();\nconst mm = String(bookingDate.getMonth() + 1).padStart(2, \"0\");\nconst dd = String(bookingDate.getDate()).padStart(2, \"0\");\nconst formattedDate = `${yyyy}-${mm}-${dd}`;\n\nlet hour = 12;\nlet minute = \"00\";\nconst timeMatch = rawTime.match(/(\\d{1,2})(?::(\\d{2}))?\\s*(am|pm)?/);\nif (timeMatch) {\n  hour = parseInt(timeMatch[1]);\n  minute = timeMatch[2] || \"00\";\n  const meridian = timeMatch[3];\n  if (meridian === \"pm\" && hour < 12) hour += 12;\n  if (meridian === \"am\" && hour === 12) hour = 0;\n}\nconst formattedTime = `${String(hour).padStart(2, \"0\")}:${minute}`;\n\nlet endHour = hour + 1;\nif (endHour > 23) endHour = 23;\nconst formattedEndTime = `${String(endHour).padStart(2, \"0\")}:${minute}`;\n\nfunction formatPhoneForWhatsApp(phone) {\n  let cleaned = (phone || \"\").replace(/[^\\d+]/g, \"\");\n  if (cleaned.startsWith(\"+\")) return cleaned;\n  if (cleaned.startsWith(\"0\")) return \"+234\" + cleaned.slice(1);\n  if (cleaned.startsWith(\"234\")) return \"+\" + cleaned;\n  return \"+234\" + cleaned;\n}\n\nconst whatsappPhone = formatPhoneForWhatsApp(args.phone);\n\n// Customer email collected by the Vapi agent (may be empty if not captured)\nconst rawEmail = (args.email || \"\").trim();\nconst emailValid = /^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/.test(rawEmail);\nconst restaurantEmail = \"YOUR_RESTAURANT_EMAIL@example.com\";\n\nreturn {\n  name: args.name,\n  phone: args.phone,\n  whatsappPhone: whatsappPhone,\n  email: rawEmail,\n  emailValid: emailValid,\n  emailTo: emailValid ? rawEmail : restaurantEmail,\n  party_size: args.party_size,\n  notes: args.notes || \"\",\n  date: formattedDate,\n  time: formattedTime,\n  startDateTime: `${formattedDate}T${formattedTime}:00`,\n  endDateTime: `${formattedDate}T${formattedEndTime}:00`\n};"
      }
    },
    {
      "id": "bba6f899-3341-4ca5-b8b1-14cf04be08e9",
